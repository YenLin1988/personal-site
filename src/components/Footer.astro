---
import { SITE_AUTHOR, SOCIAL_LINKS } from '../consts';
const year = new Date().getFullYear();
---

<footer class="mt-16 border-t border-sand bg-cream">
	<div class="mx-auto flex max-w-5xl flex-col items-center justify-between gap-3 px-4 py-8 text-sm text-stone sm:flex-row">
		<span>&copy; {year} {SITE_AUTHOR}.</span>
		<div class="flex items-center gap-4">
			<a
				href={SOCIAL_LINKS.github}
				target="_blank"
				rel="noopener noreferrer"
				class="hover:text-ink"
			>
				GitHub
			</a>
			<a href={SOCIAL_LINKS.email} class="hover:text-ink">Email</a>
			<a href="/rss.xml" class="hover:text-ink">RSS</a>
			<a href="/privacy" class="hover:text-ink">隱私權</a>
		</div>
	</div>
</footer>
