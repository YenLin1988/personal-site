---
import { SITE_TITLE, SOCIAL_LINKS } from '../consts';
import HeaderLink from './HeaderLink.astro';
---

<header class="border-b border-sand bg-paper/85 backdrop-blur sticky top-0 z-50">
	<nav class="mx-auto flex max-w-5xl items-center justify-between px-4 py-3">
		<a
			href="/"
			class="font-display text-lg font-bold tracking-tight text-ink hover:text-[color:var(--color-accent)]"
		>
			{SITE_TITLE}
		</a>

		<div class="flex items-center gap-1">
			<HeaderLink href="/">首頁</HeaderLink>
			<HeaderLink href="/blog">部落格</HeaderLink>
			<HeaderLink href="/calendar">行事曆</HeaderLink>
			<HeaderLink href="/projects">作品</HeaderLink>
			<HeaderLink href="/about">關於</HeaderLink>
		</div>

		<div class="flex items-center gap-3">
			<button
				type="button"
				data-theme-toggle
				class="text-stone transition-colors hover:text-ink"
				aria-label="切換深色／淺色模式"
				title="切換深色／淺色模式"
			>
				<!-- 太陽（淺色顯示，深色隱藏） -->
				<svg
					viewBox="0 0 24 24"
					width="20"
					height="20"
					fill="none"
					stroke="currentColor"
					stroke-width="2"
					stroke-linecap="round"
					stroke-linejoin="round"
					aria-hidden="true"
					class="dark:hidden"
				>
					<circle cx="12" cy="12" r="4"></circle>
					<path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M4.93 19.07l1.41-1.41M17.66 6.34l1.41-1.41"></path>
				</svg>
				<!-- 月亮（深色顯示） -->
				<svg
					viewBox="0 0 24 24"
					width="20"
					height="20"
					fill="none"
					stroke="currentColor"
					stroke-width="2"
					stroke-linecap="round"
					stroke-linejoin="round"
					aria-hidden="true"
					class="hidden dark:block"
				>
					<path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path>
				</svg>
			</button>

			<a
				href={SOCIAL_LINKS.github}
				target="_blank"
				rel="noopener noreferrer"
				class="hidden text-stone transition-colors hover:text-ink sm:inline-block"
				aria-label="GitHub"
			>
				<svg viewBox="0 0 16 16" width="20" height="20" aria-hidden="true">
					<path
						fill="currentColor"
						d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.012 8.012 0 0 0 16 8c0-4.42-3.58-8-8-8z"
					></path>
				</svg>
			</a>
			<a
				href="/rss.xml"
				class="hidden text-stone transition-colors hover:text-ink sm:inline-block"
				aria-label="RSS"
			>
				<svg viewBox="0 0 24 24" width="20" height="20" fill="currentColor" aria-hidden="true">
					<path d="M6.18 17.82a2.18 2.18 0 1 1-4.36 0 2.18 2.18 0 0 1 4.36 0zM4 4.44v3.18c8.06 0 14.62 6.56 14.62 14.62h3.18c0-9.83-7.97-17.8-17.8-17.8zm0 6.36v3.18c4.85 0 8.84 3.99 8.84 8.84h3.18c0-6.61-5.42-12.02-12.02-12.02z"></path>
				</svg>
			</a>
		</div>
	</nav>
</header>
