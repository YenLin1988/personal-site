---
import { render } from 'astro:content';
import BlogPost from '../../layouts/BlogPost.astro';
import RelatedPosts from '../../components/RelatedPosts.astro';
import { getAllPosts, type AnyPost } from '../../lib/all-posts';
import { getReadingTime } from '../../lib/reading-time';
import { getRelatedPosts } from '../../lib/related-posts';

export async function getStaticPaths() {
	const posts = await getAllPosts();
	return posts.map((post) => ({
		params: { slug: post.id },
		props: { post, allPosts: posts },
	}));
}

type Props = {
	post: AnyPost;
	allPosts: AnyPost[];
};

const { post, allPosts } = Astro.props;
const { Content, headings } = await render(post);
const readingMinutes = getReadingTime(post.body ?? '');
const related = getRelatedPosts(post, allPosts);
---

<BlogPost {...post.data} headings={headings} readingMinutes={readingMinutes} slug={post.id}>
	<Content />
	<RelatedPosts slot="related" posts={related} />
</BlogPost>
