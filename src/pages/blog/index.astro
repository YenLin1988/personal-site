---
import { Image } from 'astro:assets';
import Base from '../../layouts/Base.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import { SITE_TITLE } from '../../consts';
import { getAllPosts } from '../../lib/all-posts';
import { getReadingTime } from '../../lib/reading-time';

const posts = (await getAllPosts()).map((post) => ({
	...post,
	readingMinutes: getReadingTime(post.body ?? ''),
}));
---

<Base title={`部落格 · ${SITE_TITLE}`} description="所有部落格文章列表。">
	<section class="mx-auto max-w-5xl px-4 py-16">
		<header class="mb-10 flex items-end justify-between">
			<div>
				<h1 class="text-4xl font-bold text-ink">部落格</h1>
				<p class="mt-2 text-mocha">想法、學習筆記、雜記，共 {posts.length} 篇。</p>
			</div>
			<a href="/tags/" class="text-sm text-clay hover:underline">瀏覽標籤 →</a>
		</header>

		<ul class="grid gap-8 sm:grid-cols-2">
			{
				posts.map((post) => (
					<li>
						<a href={`/blog/${post.id}/`} class="group block">
							{post.data.heroImage && (
								<Image
									width={720}
									height={360}
									src={post.data.heroImage}
									alt=""
									class="mb-3 aspect-video w-full rounded-lg object-cover transition-shadow group-hover:shadow-md"
								/>
							)}
							<p class="text-sm text-stone">
								<FormattedDate date={post.data.pubDate} />
								<span class="mx-1">·</span>
								<span>閱讀約 {post.readingMinutes} 分鐘</span>
							</p>
							<h2 class="mt-1 text-xl font-semibold text-ink group-hover:text-[color:var(--color-accent)]">
								{post.data.title}
							</h2>
							<p class="mt-2 line-clamp-2 text-sm text-mocha">
								{post.data.description}
							</p>
						</a>
					</li>
				))
			}
		</ul>
	</section>
</Base>
