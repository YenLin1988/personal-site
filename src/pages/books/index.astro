---
import { Image } from 'astro:assets';
import { getCollection, type CollectionEntry } from 'astro:content';
import Base from '../../layouts/Base.astro';
import { SITE_TITLE } from '../../consts';

const all = await getCollection('books');

const statusOrder: Record<CollectionEntry<'books'>['data']['status'], number> = {
	reading: 0,
	read: 1,
	wantToRead: 2,
};

const sorted = [...all].sort((a, b) => {
	const sa = statusOrder[a.data.status];
	const sb = statusOrder[b.data.status];
	if (sa !== sb) return sa - sb;
	const ta = a.data.dateRead?.valueOf() ?? 0;
	const tb = b.data.dateRead?.valueOf() ?? 0;
	return tb - ta;
});

const statusLabel: Record<CollectionEntry<'books'>['data']['status'], string> = {
	reading: '在讀',
	read: '讀過',
	wantToRead: '想讀',
};
---

<Base title={`書單 · ${SITE_TITLE}`} description="我讀過、正在讀、想讀的書。">
	<section class="mx-auto max-w-5xl px-4 py-16">
		<header class="mb-10">
			<p class="text-xs font-medium tracking-[0.3em] text-stone uppercase">Bookshelf</p>
			<h1 class="mt-2 text-4xl font-bold text-ink">書單</h1>
			<p class="mt-2 text-mocha">
				讀過、正在讀、想讀的書。共 {all.length} 本。
			</p>
		</header>

		{
			sorted.length === 0 ? (
				<p class="text-mocha">還沒有書目。</p>
			) : (
				<ul class="grid gap-8 sm:grid-cols-2 lg:grid-cols-3">
					{sorted.map((book) => (
						<li>
							<a href={`/books/${book.id}/`} class="group block">
								<div class="relative mb-4 aspect-[2/3] overflow-hidden rounded-lg bg-cream shadow-sm transition-shadow group-hover:shadow-md">
									{book.data.cover ? (
										<Image
											src={book.data.cover}
											alt={`${book.data.title} 封面`}
											width={400}
											height={600}
											class="h-full w-full object-cover"
										/>
									) : (
										<div class="flex h-full items-center justify-center p-4 text-center text-mocha">
											<span class="font-display text-lg">{book.data.title}</span>
										</div>
									)}
									<span
										class:list={[
											'absolute top-2 right-2 rounded-full px-2.5 py-1 text-[10px] font-medium tracking-wider uppercase backdrop-blur',
											book.data.status === 'reading' &&
												'bg-clay/90 text-paper',
											book.data.status === 'read' &&
												'bg-paper/85 text-mocha',
											book.data.status === 'wantToRead' &&
												'bg-paper/85 text-stone',
										]}
									>
										{statusLabel[book.data.status]}
									</span>
								</div>

								<h2 class="font-display text-lg leading-snug font-semibold text-ink group-hover:text-[color:var(--color-accent)]">
									{book.data.title}
								</h2>
								<p class="mt-1 text-sm text-mocha">{book.data.author}</p>
								{book.data.rating && (
									<p class="mt-2 text-sm text-clay">
										{'★'.repeat(book.data.rating)}
										<span class="text-stone">
											{'★'.repeat(5 - book.data.rating)}
										</span>
									</p>
								)}
							</a>
						</li>
					))}
				</ul>
			)
		}
	</section>
</Base>
