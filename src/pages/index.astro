---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';
import FormattedDate from '../components/FormattedDate.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';

const recentPosts = (await getCollection('blog'))
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
	.slice(0, 3);

const featuredProjects = (await getCollection('projects'))
	.filter((p) => p.data.featured)
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
	.slice(0, 3);
---

<Base title={SITE_TITLE} description={SITE_DESCRIPTION}>
	<!-- 創造理念 / Manifesto -->
	<section class="border-y border-sand bg-cream/60 py-20 sm:py-24">
		<div class="mx-auto max-w-3xl px-4">
			<p class="text-sm font-medium tracking-[0.25em] text-stone uppercase">
				創造理念 · Manifesto
			</p>
			<h2 class="mt-3 text-4xl font-bold text-ink sm:text-5xl">
				理型 <span class="ml-2 font-normal text-stone italic">εἶδος</span>
			</h2>
			<p class="mt-3 text-stone">事物最純粹、最完美的型態。</p>

			<div class="mt-10 space-y-6 text-lg leading-loose text-mocha">
				<p>
					兩千多年前，柏拉圖提出<strong class="text-ink">理型論</strong>：
					世間萬物，皆是「理型」的摹仿。
					理型是事物最純粹、最完美的型態 ——
					永恆、不變、唯一，超越時間與空間，
					存在於可感世界之外。
				</p>
				<p>
					我們眼前的每一張桌子、每一匹馬、每一個善行，
					之所以是它所是，是因為它<strong class="text-ink">分有</strong>了它的理型。
					現實是影子，理型才是那道光。
				</p>
			</div>

			<blockquote
				class="mt-10 border-l-4 border-[color:var(--color-accent)] pl-6 text-lg leading-loose text-coffee italic"
			>
				而這個網站，是一場朝向理型的練習。<br />
				寫下的每篇文章、做出的每件作品，<br />
				都不會抵達完美 —— 但都是對那個更純粹版本的趨近。
			</blockquote>
		</div>
	</section>

	<!-- Recent posts -->
	{
		recentPosts.length > 0 && (
			<section class="mx-auto max-w-5xl px-4 py-12">
				<div class="mb-6 flex items-end justify-between">
					<h2 class="text-2xl font-bold text-ink">最新文章</h2>
					<a href="/blog" class="text-sm text-[color:var(--color-accent)] hover:underline">
						全部文章 →
					</a>
				</div>
				<ul class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
					{recentPosts.map((post) => (
						<li>
							<a href={`/blog/${post.id}/`} class="group block">
								<h3 class="text-lg font-semibold text-ink group-hover:text-[color:var(--color-accent)]">
									{post.data.title}
								</h3>
								<p class="mt-1 text-sm text-stone">
									<FormattedDate date={post.data.pubDate} />
								</p>
								<p class="mt-2 line-clamp-2 text-sm text-mocha">
									{post.data.description}
								</p>
							</a>
						</li>
					))}
				</ul>
			</section>
		)
	}

	<!-- Featured projects -->
	{
		featuredProjects.length > 0 && (
			<section class="mx-auto max-w-5xl px-4 py-12">
				<div class="mb-6 flex items-end justify-between">
					<h2 class="text-2xl font-bold text-ink">精選作品</h2>
					<a href="/projects" class="text-sm text-[color:var(--color-accent)] hover:underline">
						全部作品 →
					</a>
				</div>
				<ul class="grid gap-6 sm:grid-cols-2">
					{featuredProjects.map((project) => (
						<li class="rounded-xl border border-sand p-5 transition-shadow hover:shadow-md">
							<a href={`/projects/${project.id}/`} class="group block">
								<h3 class="text-lg font-semibold text-ink group-hover:text-[color:var(--color-accent)]">
									{project.data.title}
								</h3>
								<p class="mt-2 text-sm text-mocha">{project.data.description}</p>
								{project.data.tags.length > 0 && (
									<ul class="mt-3 flex flex-wrap gap-2">
										{project.data.tags.map((tag) => (
											<li class="rounded-full bg-sand px-2.5 py-0.5 text-xs text-mocha">
												{tag}
											</li>
										))}
									</ul>
								)}
							</a>
						</li>
					))}
				</ul>
			</section>
		)
	}
</Base>
