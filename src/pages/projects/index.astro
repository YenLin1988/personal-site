---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import { SITE_TITLE } from '../../consts';

const projects = (await getCollection('projects')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<Base title={`作品 · ${SITE_TITLE}`} description="我做過的專案與作品集。">
	<section class="mx-auto max-w-5xl px-4 py-16">
		<header class="mb-10">
			<h1 class="text-4xl font-bold text-ink">作品</h1>
			<p class="mt-2 text-mocha">過去做過的專案，共 {projects.length} 件。</p>
		</header>

		<ul class="grid gap-6 sm:grid-cols-2">
			{
				projects.map((project) => (
					<li class="rounded-xl border border-sand transition-shadow hover:shadow-md">
						<a href={`/projects/${project.id}/`} class="group block h-full p-5">
							{project.data.heroImage && (
								<Image
									width={720}
									height={360}
									src={project.data.heroImage}
									alt=""
									class="mb-4 aspect-video w-full rounded-lg object-cover"
								/>
							)}
							<h2 class="text-xl font-semibold text-ink group-hover:text-[color:var(--color-accent)]">
								{project.data.title}
							</h2>
							<p class="mt-2 text-sm text-mocha">{project.data.description}</p>
							{project.data.tags.length > 0 && (
								<ul class="mt-3 flex flex-wrap gap-2">
									{project.data.tags.map((tag) => (
										<li class="rounded-full bg-sand px-2.5 py-0.5 text-xs text-mocha">
											{tag}
										</li>
									))}
								</ul>
							)}
						</a>
					</li>
				))
			}
		</ul>
	</section>
</Base>
