---
import { Image } from 'astro:assets';
import { getCollection, type CollectionEntry } from 'astro:content';
import Base from '../../layouts/Base.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import { SITE_TITLE } from '../../consts';
import { getReadingTime } from '../../lib/reading-time';

export async function getStaticPaths() {
	const allPosts = await getCollection('blog');
	const tagMap = new Map<string, CollectionEntry<'blog'>[]>();
	for (const post of allPosts) {
		for (const tag of post.data.tags ?? []) {
			if (!tagMap.has(tag)) tagMap.set(tag, []);
			tagMap.get(tag)!.push(post);
		}
	}
	return [...tagMap.entries()].map(([tag, posts]) => ({
		params: { tag },
		props: { tag, posts },
	}));
}

type Props = {
	tag: string;
	posts: CollectionEntry<'blog'>[];
};

const { tag, posts } = Astro.props;
const sorted = posts
	.map((p) => ({ ...p, readingMinutes: getReadingTime(p.body ?? '') }))
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<Base title={`#${tag} · ${SITE_TITLE}`} description={`所有標記為「${tag}」的文章。`}>
	<section class="mx-auto max-w-5xl px-4 py-16">
		<header class="mb-10">
			<p class="text-sm tracking-widest text-stone uppercase">Tag</p>
			<h1 class="mt-2 text-4xl font-bold text-ink">#{tag}</h1>
			<p class="mt-2 text-mocha">共 {posts.length} 篇文章。</p>
			<p class="mt-4">
				<a href="/tags/" class="text-sm text-clay hover:underline">
					← 所有標籤
				</a>
			</p>
		</header>

		<ul class="grid gap-8 sm:grid-cols-2">
			{
				sorted.map((post) => (
					<li>
						<a href={`/blog/${post.id}/`} class="group block">
							{post.data.heroImage && (
								<Image
									width={720}
									height={360}
									src={post.data.heroImage}
									alt=""
									class="mb-3 aspect-video w-full rounded-lg object-cover transition-shadow group-hover:shadow-md"
								/>
							)}
							<p class="text-sm text-stone">
								<FormattedDate date={post.data.pubDate} />
								<span class="mx-1">·</span>
								<span>閱讀約 {post.readingMinutes} 分鐘</span>
							</p>
							<h2 class="mt-1 text-xl font-semibold text-ink group-hover:text-[color:var(--color-accent)]">
								{post.data.title}
							</h2>
							<p class="mt-2 line-clamp-2 text-sm text-mocha">
								{post.data.description}
							</p>
						</a>
					</li>
				))
			}
		</ul>
	</section>
</Base>
